# Rumina 鬼教官 — Phase 1 環境変数
# このファイルを .env にコピーして値を入れる（.env はコミットしない）

# 必須：OpenAI APIキー（Whisper文字起こし用）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 認証・セッション（本番は必ず設定）
SESSION_SECRET=change-me-please
OWNER_USER=川上
OWNER_PASSWORD=set-your-own

# LINEログイン（LINE Developers の「LINEログイン」チャネル）※設定すると「LINEでログイン」ボタンが出る
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
# LINE_CALLBACK_URL は未設定ならアクセス中のホストから自動生成（例 https://xxx.up.railway.app/api/line/callback）
LINE_CALLBACK_URL=
# 川上のLINEユーザーIDを入れると、その人だけ管理者(owner)としてログインできる（任意）
OWNER_LINE_ID=

# データ永続化（重要）：ユーザー・登録モデル・診断ログの保存先。
# 本番(Railway)は Volume をマウントして必ず /data を指すこと。未設定だと
# アプリ直下 ./data に保存され、再デプロイで消える。
DATA_DIR=/data
# 診断ログの保持件数（索引の上限。超えたら古いものから索引を落とす）
REPORT_LOG_CAP=1000

# 録音・解析への同意。文言を改訂したらこの版を上げると全員に再同意を求める。
CONSENT_VERSION=2026-07-15
# 文字起こし後に音声ファイルを自動削除する（個人情報を残さない運用）。on/true で有効・既定は保持。
PURGE_AUDIO_AFTER_ANALYZE=

# cyzen連携（行動量＝訪問数・アポの確定値）。CSV書き出しを置いたフォルダを指す。
#   <dir>/user-master.csv      … ユーザーマスター(utf-8)
#   <dir>/action-history.csv   … 行動履歴(Shift_JIS・任意/大容量)
#   <dir>/report/*.csv         … 報告書各種(Shift_JIS)
# 未設定ならcyzen照合はオフ（従来どおりGPS/文面推定）。将来はAPI連携に差し替え。
CYZEN_DATA_DIR=
# 行動履歴(大容量)の読み込みを飛ばす場合は on
CYZEN_SKIP_HISTORY=

# LINE bot 個別コーチング連携（/api/coach-context）の共有シークレット。
# botサーバーがこのキー付きで叩くと、LINE userId→本人の最新診断＋一言処方を返す。空なら無効。
BOT_API_SECRET=

# 任意
PORT=4180
WHISPER_MODEL=whisper-1
VISIT_GAP_SEC=60      # この秒数以上の無音を「別の家」の境界とみなす
IDLE_GAP_SEC=1200     # この秒数(20分)以上の空白を「サボり疑い」候補に

# Rumina Coach 連携（任意。測定完了時にCoachのwebhookへ解析結果を送る）
# Coachの測定依頼リンク（?staff=&iv=）経由でアクセスした場合のみ送信される。
# 未設定なら何も送らない（既存の使い方に影響なし）。
COACH_WEBHOOK_URL=
COACH_WEBHOOK_SECRET=
